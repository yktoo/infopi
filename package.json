{
    "name": "infopi",
    "version": "2.17.2",
    "main": "bootstrap.js",
    "type": "module",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build --configuration development",
        "build:prod": "ng build --base-href ./",
        "test": "ng test",
        "lint": "ng lint",
        "electron": "ng build --base-href ./ && electron --no-sandbox .",
        "package": "yarn build:prod && node package.js",
        "deploy": "yarn package && yarn deploy:copy && yarn deploy:install && yarn deploy:clean && yarn deploy:reboot",
        "deploy:clean": "ssh infopi rm infopi_${npm_package_version}_arm64.deb",
        "deploy:copy": "scp dist/installers/infopi_${npm_package_version}_arm64.deb infopi:",
        "deploy:install": "ssh infopi sudo dpkg -i infopi_${npm_package_version}_arm64.deb",
        "deploy:reboot": "ssh infopi sudo reboot",
        "restart-infopi": "ssh infopi killall infopi; ssh infopi 'env DISPLAY=:0 nohup infopi &>/dev/null &'"
    },
    "private": true,
    "dependencies": {
        "@angular/common": "^22.0.1",
        "@angular/core": "^22.0.1",
        "@angular/forms": "^22.0.1",
        "@angular/platform-browser": "^22.0.1",
        "@angular/platform-browser-dynamic": "^22.0.1",
        "chart.js": "^4.5.1",
        "chartjs-plugin-annotation": "^3.1.0",
        "ng2-charts": "^10.0.0",
        "rxjs": "^7.8.2",
        "stream": "^0.0.3",
        "tslib": "^2.8.1",
        "weather-icons": "github:erikflowers/weather-icons",
        "xml-js": "^1.6.11",
        "zone.js": "^0.16.2"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^22.0.0",
        "@angular-eslint/eslint-plugin": "^22.0.0",
        "@angular-eslint/eslint-plugin-template": "^22.0.0",
        "@angular-eslint/schematics": "^22.0.0",
        "@angular-eslint/template-parser": "^22.0.0",
        "@angular/build": "^22.0.1",
        "@angular/cli": "^22.0.1",
        "@angular/compiler": "^22.0.1",
        "@angular/compiler-cli": "^22.0.1",
        "@angular/language-service": "^22.0.1",
        "@electron/packager": "^20.0.1",
        "@eslint/js": "^10.0.1",
        "@types/node": "^24.13.2",
        "@typescript-eslint/eslint-plugin": "^8.61.0",
        "@typescript-eslint/parser": "^8.61.0",
        "angular-eslint": "^22.0.0",
        "electron": "^42.4.0",
        "electron-installer-debian": "^3.2.0",
        "eslint": "^10.5.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^63.0.2",
        "eslint-plugin-no-only-tests": "^3.4.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "jsdom": "^29.1.1",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.61.0",
        "vitest": "^4.1.8"
    },
    "author": {
        "name": "Dmitry Kann",
        "email": "yktooo@gmail.com",
        "url": "https://yktoo.com/"
    },
    "description": "Single page info kiosk application",
    "directories": {
        "doc": "doc"
    },
    "keywords": [
        "InfoPi",
        "kiosk",
        "Angular",
        "Electron",
        "clock",
        "weather",
        "timetables",
        "Buienradar"
    ],
    "license": "MIT",
    "packageManager": "yarn@4.17.0"
}
