{
    "name": "infopi",
    "version": "2.12.0",
    "main": "bootstrap.js",
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build --configuration development",
        "build:prod": "ng build --base-href ./",
        "test": "ng test",
        "test:ci": "ng test --no-watch --no-progress --browsers=ChromeHeadlessNoSandbox",
        "lint": "ng lint",
        "electron": "ng build --base-href ./ && electron --no-sandbox .",
        "package": "yarn run build:prod && node package.js",
        "package:rpi": "yarn run build:prod && node package.js rpi",
        "deploy": "yarn run package:rpi && scp dist/installers/infopi_*_arm64.deb infopi: && ssh infopi sudo dpkg -i infopi_*_arm64.deb && ssh infopi rm infopi_*_arm64.deb && yarn run restart-infopi",
        "restart-infopi": "ssh infopi killall infopi; ssh infopi 'env DISPLAY=:0 nohup infopi &>/dev/null &'"
    },
    "private": true,
    "dependencies": {
        "@angular/animations": "^21.2.7",
        "@angular/cdk": "^21.2.5",
        "@angular/common": "^21.2.7",
        "@angular/core": "^21.2.7",
        "@angular/forms": "^21.2.7",
        "@angular/platform-browser": "^21.2.7",
        "@angular/platform-browser-dynamic": "^21.2.7",
        "chart.js": "^4.5.1",
        "ng2-charts": "^10.0.0",
        "rxjs": "^7.8.2",
        "stream": "^0.0.3",
        "tslib": "^2.8.1",
        "weather-icons": "^1.3.2",
        "xml-js": "^1.6.11",
        "zone.js": "^0.16.1"
    },
    "devDependencies": {
        "@angular-eslint/builder": "^21.3.1",
        "@angular-eslint/eslint-plugin": "^21.3.1",
        "@angular-eslint/eslint-plugin-template": "^21.3.1",
        "@angular-eslint/schematics": "^21.3.1",
        "@angular-eslint/template-parser": "^21.3.1",
        "@angular/build": "^21.2.6",
        "@angular/cli": "^21.2.6",
        "@angular/compiler": "^21.2.7",
        "@angular/compiler-cli": "^21.2.7",
        "@angular/language-service": "^21.2.7",
        "@types/jasmine": "^6.0.0",
        "@types/node": "^25.5.2",
        "@typescript-eslint/eslint-plugin": "^8.58.0",
        "@typescript-eslint/parser": "^8.58.0",
        "codelyzer": "^6.0.2",
        "electron": "^41.1.1",
        "electron-installer-debian": "^3.2.0",
        "electron-packager": "^17.1.2",
        "eslint": "^10.2.0",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^62.9.0",
        "eslint-plugin-prefer-arrow": "^1.2.3",
        "jasmine-core": "^6.1.0",
        "jasmine-reporters": "^2.5.2",
        "jasmine-spec-reporter": "^7.0.0",
        "karma": "^6.4.4",
        "karma-chrome-launcher": "^3.2.0",
        "karma-coverage": "^2.2.1",
        "karma-jasmine": "^5.1.0",
        "karma-jasmine-html-reporter": "^2.2.0",
        "ng-mocks": "^14.15.2",
        "typescript": "~5.9.3"
    },
    "author": {
        "name": "Dmitry Kann",
        "email": "yktooo@gmail.com",
        "url": "https://yktoo.com/"
    },
    "description": "Single page info kiosk application",
    "directories": {
        "doc": "doc"
    },
    "keywords": [
        "InfoPi",
        "kiosk",
        "Angular",
        "Electron",
        "clock",
        "weather",
        "timetables",
        "Buienradar"
    ],
    "license": "MIT",
    "packageManager": "yarn@4.13.0"
}
